# ─── Supabase ───────────────────────────────────────────────────────
# Encontrás estos valores en: supabase.com > tu proyecto > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Uso ────────────────────────────────────────────────────────────
# 1. Copiá este archivo a .env.local
# 2. Reemplazá los valores con los de tu proyecto Supabase
# 3. NUNCA subas .env.local a Git (ya está en .gitignore)
